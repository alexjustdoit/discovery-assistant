# Copy this to .streamlit/secrets.toml for local Streamlit secrets,
# or paste the key/value pairs into the Streamlit Cloud secrets UI.
#
# secrets.toml is gitignored. Never commit real keys.

USE_LOCAL_LLM = "false"
OPENAI_API_KEY = "sk-..."
ANTHROPIC_API_KEY = "sk-ant-..."

# Optional overrides
# OPENAI_MODEL = "gpt-5.4-nano"
# CLAUDE_MODEL = "claude-haiku-4-5-20251001"
